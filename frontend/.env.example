# Mad Vapers API base
# Keep host aligned with frontend host for cookie auth (localhost with localhost).
# For deployment, set to your HTTPS API URL (for token-based auth, separate origin is fine).
VITE_API_BASE_URL=http://localhost:8000/api

# Auth strategy:
# - token  : recommended for separate frontend/backend domains (avoids CSRF cookie issues)
# - cookie : Sanctum cookie mode (same-site subdomains with proper session/cors setup)
# - hybrid : keeps both paths available (default)
VITE_AUTH_STRATEGY=hybrid

# Realtime AJAX polling (set to "false" to disable)
VITE_REALTIME_POLLING=true
VITE_REALTIME_APPROVAL_QUEUE_MS=3000
VITE_REALTIME_INVENTORY_MS=5000
VITE_REALTIME_LEDGER_MS=5000
VITE_REALTIME_ADJUSTMENTS_MS=5000
VITE_REALTIME_TRANSFERS_MS=6000
VITE_REALTIME_PURCHASE_ORDERS_MS=6000

# Web Push (must match backend WEB_PUSH_VAPID_PUBLIC_KEY)
VITE_WEB_PUSH_PUBLIC_KEY=
