# Mad Vapers API base
# Keep host aligned with frontend host for cookie auth (localhost with localhost).
VITE_API_BASE_URL=http://localhost:8000/api

# Laravel Reverb websocket
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Realtime AJAX polling (set to "false" to disable)
VITE_REALTIME_POLLING=true
VITE_REALTIME_APPROVAL_QUEUE_MS=1000
VITE_REALTIME_INVENTORY_MS=5000
VITE_REALTIME_LEDGER_MS=5000
VITE_REALTIME_ADJUSTMENTS_MS=5000
VITE_REALTIME_TRANSFERS_MS=6000
VITE_REALTIME_PURCHASE_ORDERS_MS=6000
