APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Security hardening
SANCTUM_TOKEN_EXPIRATION=120
SANCTUM_TOKEN_PREFIX=mv_
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOGIN_ALLOWED_ORIGINS=
LOGIN_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=180
PUBLIC_API_RATE_LIMIT_PER_MINUTE=120
SENSITIVE_ACTIONS_RATE_LIMIT_PER_MINUTE=30
SEED_DEMO_DATA=false
SEED_ROLE_USERS=false
SEED_DEFAULT_PASSWORD=
SEED_ADMIN_EMAIL=admin@madvapers.com
SEED_ADMIN_PASSWORD=admin123
SEED_BRANCHES_JSON=
SEED_DEACTIVATE_UNLISTED_BRANCHES=false

# Production deployment templates:
# 1) Recommended for separate frontend/backend origins (token-based API auth):
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://madvapers-backend.your-host.com
# CORS_ALLOWED_ORIGINS=https://madvapers-frontend.your-host.com
# LOGIN_ALLOWED_ORIGINS=https://madvapers-frontend.your-host.com
# SANCTUM_STATEFUL_DOMAINS=
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
#
# 2) Cookie-based Sanctum across same-site subdomains (advanced):
# APP_URL=https://api.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com
# SANCTUM_STATEFUL_DOMAINS=app.example.com,api.example.com
# SESSION_DOMAIN=.example.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
